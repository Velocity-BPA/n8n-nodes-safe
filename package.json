{
  "name": "n8n-nodes-safe",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Safe (Gnosis Safe) multi-signature wallet providing 10 resources and 50+ operations for transaction proposals, signature collection, and execution automation.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-safe.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-safe#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-safe/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "safe",
    "gnosis-safe",
    "multisig",
    "multi-signature",
    "smart-wallet",
    "ethereum",
    "polygon",
    "arbitrum",
    "optimism",
    "base",
    "blockchain",
    "web3",
    "defi",
    "dao",
    "treasury",
    "wallet",
    "automation"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SafeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Safe/Safe.node.js",
      "dist/nodes/Safe/SafeTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "ethers": "^6.10.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
